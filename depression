<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Depression Self-Assessment | TestingNation Wellness</title>

<link rel="stylesheet" href="css/style.css">

<style>

/* DISCLAIMER */
.disclaimer {
  max-width: 800px;
  margin: 30px auto;
  padding: 20px;
  background: #fff8e1;
  border-left: 5px solid #f0ad4e;
  border-radius: 6px;
  font-size: 14px;
}

/* FORM */
.assessment {
  max-width: 800px;
  margin: 40px auto;
  padding: 20px;
}

.question {
  margin-bottom: 25px;
}

.question p {
  font-weight: 500;
  margin-bottom: 10px;
}

.question label {
  display: block;
  margin-bottom: 5px;
  cursor: pointer;
}

/* PROGRESS */
#progress {
  text-align: right;
  margin-bottom: 20px;
  font-size: 14px;
  color: #555;
}

/* BUTTON */
.assessment button {
  margin-top: 20px;
  padding: 12px 20px;
  background: #145aa0;
  color: white;
  border: none;
  border-radius: 6px;
  cursor: pointer;
}

/* SCORE BAR */
.score-bar {
  position: relative;
  height: 20px;
  width: 100%;
  max-width: 600px;
  margin: 20px auto;
  background: linear-gradient(to right, green, yellow, orange, red);
  border-radius: 10px;
}

#score-marker {
  position: absolute;
  top: -5px;
  width: 10px;
  height: 30px;
  background: black;
  border-radius: 3px;
  left: 0%;
}

/* RESULTS */
#results {
  max-width: 800px;
  margin: 40px auto;
  padding: 20px;
  display: none;
  text-align: center;
}

/* MEDICAL SUMMARY CARD */
.summary-card {
  margin-top: 30px;
  padding: 20px;
  background: white;
  border: 1px solid #ddd;
  border-radius: 8px;
  text-align: left;
}

.summary-card h3 {
  margin-bottom: 10px;
  color: #145aa0;
}

.summary-card p {
  margin-bottom: 8px;
  font-size: 14px;
}

.clinical-note {
  margin-top: 15px;
  font-size: 13px;
  color: #555;
}

</style>

</head>

<body>

<!-- HERO -->
<section class="hero">

<video autoplay muted loop playsinline class="hero-video">
<source src="video/banner.mp4" type="video/mp4">
</video>

<nav>
<div class="nav-container">
<a href="index.html" class="home-icon">⌂</a>
<div class="menu-toggle" id="menu-toggle">☰</div>
</div>
</nav>

<div class="hero-content">
<h1>Depression Self-Assessment</h1>
<p>Reflect on your recent experiences</p>
</div>

</section>

<!-- SIDE MENU -->
<div id="menu">
<ul>
<li><a href="about.html">About</a></li>
<li><a href="resources.html">Resources</a></li>
<li><a href="#">Journal</a></li>
<li><a href="#">Blog</a></li>
